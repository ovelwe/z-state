{
  "name": "@ovelwe/z-state",
  "version": "1.1.2",
  "description": "z-state - legacy state-manager for React 16-19",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/react": "^19.2.14",
    "@types/use-sync-external-store": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "keywords": [
    "react",
    "state",
    "state-management",
    "store",
    "hooks",
    "z-manager",
    "z"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ovelwe/z-state.git"
  },
  "license": "MIT",
  "author": "Danil Zobkov 2026",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "use-sync-external-store": "^1.6.0"
  }
}
